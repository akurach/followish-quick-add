{
  "manifest_version": 3,
  "name": "Followish Quick Add",
  "version": "0.2.0",
  "description": "Добавляет товар с любой открытой страницы в вишлист Followish в один клик: название, цена, галерея и варианты.",
  "minimum_chrome_version": "110",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://core.followish.io/*",
    "https://followish.io/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "В Followish",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://followish.io/*"],
      "js": ["token-sync.js"],
      "run_at": "document_idle"
    }
  ]
}
