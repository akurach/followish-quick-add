{
  "manifest_version": 3,
  "name": "Quick Add for Followish (unofficial)",
  "version": "1.0.0",
  "description": "В один клик добавляет товар с любой страницы в вишлист Followish: имя, цена, галерея и варианты. Неофициальное расширение.",
  "author": "Alexander Kurach",
  "homepage_url": "https://github.com/akurach/followish-quick-add",
  "minimum_chrome_version": "110",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://core.followish.io/*",
    "https://followish.io/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "В Followish",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://followish.io/*"],
      "js": ["token-sync.js"],
      "run_at": "document_idle"
    }
  ]
}
